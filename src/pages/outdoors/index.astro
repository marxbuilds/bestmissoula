---
import Layout from '../../layouts/Layout.astro';

const title = "Outdoors & Guides";
---

<Layout title={title}>
  <h1>{title}</h1>

  <p>
    Western Montana is built for getting outside, and this is where
    you'll find it: guided trips, local knowledge, and honest
    recommendations for exploring the area with someone who knows it
    well.
  </p>

  <p>
    Right now that means fishing — from float trips on the Blackfoot
    to winter charters on Flathead Lake, with a real comparison tool
    to help you find the right guide.
  </p>

  <p>
    <a href="/outdoors/fishing/" class="btn">🎣 Fishing →</a>
  </p>
</Layout>

<style>
  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    background: #2f4538;
    color: #faf8f4;
  }
</style>