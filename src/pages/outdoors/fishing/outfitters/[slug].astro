---
import Layout from '../../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const outfitters = await getCollection('outfitters');
  return outfitters.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const {
  name, baseTown, region, waters, fishingType,
  priceTier, priceDisplay, phone, website,
  tripTypes, speciesTargeted, seasonActive, description
} = entry.data;
---
<Layout title={name}>
  <main class="outfitter-page">
    <p class="eyebrow">{baseTown}, {region}</p>
    <h1>{name}</h1>

    <div class="content-grid">
  <div class="photo-placeholder">
    <img src="/fish-placeholder.png" alt="Photo coming soon" class="placeholder-icon" />
</div>

  <div class="main-col">
    <p class="description">{description}</p>

        <div class="tag-group">
          <span class="tag-label">Waters</span>
          <div class="pills">
            {waters.map((w) => <span class="pill">{w}</span>)}
          </div>
        </div>

        <div class="tag-group">
          <span class="tag-label">Fishing Type</span>
          <div class="pills">
            {fishingType.map((f) => <span class="pill">{f}</span>)}
          </div>
        </div>

        <div class="tag-group">
          <span class="tag-label">Trip Types</span>
          <p class="plain-value">{tripTypes}</p>
        </div>

        <div class="tag-group">
          <span class="tag-label">Species Targeted</span>
          <p class="plain-value">{speciesTargeted}</p>
        </div>

        <div class="tag-group">
          <span class="tag-label">Season Active</span>
          <p class="plain-value">{seasonActive}</p>
        </div>
      </div>

      <aside class="contact-box">
        <p class="price">{priceDisplay} <span class="price-tier">({priceTier})</span></p>
        <p class="phone"><a href={`tel:${phone}`}>{phone}</a></p>
        <p class="website"><a href={website} target="_blank" rel="noopener">Visit website</a></p>
      </aside>
    </div>
  </main>
</Layout>

<style>
  .outfitter-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
  }

  .eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #4a6670;
    font-weight: 600;
    margin: 0 0 0.25rem 0;
  }

  h1 {
    margin: 0 0 1.5rem 0;
    font-size: 2.25rem;
  }

  .content-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  grid-template-areas:
    "photo   contact"
    "maincol contact";
  gap: 2rem;
  align-items: start;
}

  .photo-placeholder {
  grid-area: photo;
  width: 100%;
  aspect-ratio: 16 / 9;
  background: #e8e4da;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

  .placeholder-icon {
    width: 30%;
    max-width: 160px;
    opacity: 0.85;
  }

.main-col {
    grid-area: maincol;
  }

  .description {
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .tag-group {
    margin-bottom: 1.25rem;
  }

  .tag-label {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #6b6558;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  .plain-value {
    margin: 0;
  }

  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .pill {
    background: #eef2f0;
    color: #4a6670;
    border: 1px solid #cdd9d6;
    border-radius: 999px;
    padding: 0.3rem 0.8rem;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .contact-box {
    grid-area: contact;
    background: #2f4538;
    color: #faf8f4;
    border-radius: 8px;
    padding: 1.5rem;
    position: sticky;
    top: 1.5rem;
  }

  .contact-box p {
    margin: 0 0 1rem 0;
  }

  .contact-box p:last-child {
    margin-bottom: 0;
  }

  .price {
    font-family: 'Fraunces', serif;
    font-size: 1.4rem;
    font-weight: 700;
  }

  .price-tier {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 400;
    opacity: 0.8;
  }

  .contact-box a {
    color: #faf8f4;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid rgba(250, 248, 244, 0.5);
  }

  .contact-box a:hover {
    border-bottom-color: #faf8f4;
  }

 @media (max-width: 700px) {
    .content-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "photo"
        "contact"
        "maincol";
    }

    .contact-box {
      position: static;
    }
  }
</style>